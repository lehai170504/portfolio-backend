# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/portfolio_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# JWT - Use a strong 256-bit secret (generate with: openssl rand -base64 32)
JWT_SECRET=change_this_to_a_very_long_random_secret_key_at_least_32_chars
JWT_EXPIRATION=86400000
JWT_REFRESH=604800000

# Email (Gmail SMTP example)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
CLOUDINARY_FOLDER=portfolio

# Admin - Change default credentials in production!
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=Admin@123
ADMIN_FULL_NAME=Portfolio Admin

# Contact
CONTACT_EMAIL=your_contact_email@example.com
FRONTEND_URL=https://yourportfolio.com
